---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Navbar from '../../components/Navbar.svelte'
import NewsletterForm from '../../components/NewsletterForm.svelte'
import ScrollProgress from '../../components/ScrollProgress.svelte'
import Footer from '../../components/Footer.svelte'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const useCases = await getCollection('useCases', ({ data }) => !data.draft)
  return useCases.map(uc => ({
    params: { slug: uc.id },
    props: { entry: uc },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article" publishedTime={entry.data.date.toISOString()} tags={entry.data.tags}>
  <Navbar client:load />

  <article class="max-w-3xl mx-auto px-6 pt-12 pb-20">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-surface-600 mb-6">
      <a href="/" class="hover:text-surface-400 transition-colors">Home</a>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <a href="/use-cases/" class="hover:text-surface-400 transition-colors">Use Cases</a>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-surface-400">{entry.data.title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">{entry.data.title}</h1>
      <p class="text-lg text-surface-400 leading-relaxed">{entry.data.description}</p>
      <div class="flex items-center gap-3 mt-4 text-sm text-surface-500">
        <time>{new Date(entry.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
        {entry.data.author && (
          <>
            <span class="w-1 h-1 rounded-full bg-surface-700" />
            <span>{entry.data.author}</span>
          </>
        )}
        {entry.data.storySource && (
          <>
            <span class="w-1 h-1 rounded-full bg-surface-700" />
            <span>via {entry.data.storySource}</span>
          </>
        )}
      </div>
    </header>

    <!-- Content -->
    <div class="prose-content max-w-none">
      <Content />
    </div>

    <!-- Tags -->
    {entry.data.tags && entry.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-12 pt-8 border-t border-surface-800">
        {entry.data.tags.map(tag => (
          <span class="px-3 py-1.5 rounded-lg bg-surface-800 text-surface-400 text-xs">{tag}</span>
        ))}
      </div>
    )}

    <!-- Share your story -->
    <div class="mt-12 p-6 rounded-xl bg-gradient-to-br from-brand-950/10 to-surface-900/30 dark:from-brand-950/20 dark:to-surface-900/50 border border-surface-800 text-center">
      <h3 class="font-semibold mb-2">🎤 Have a story like this?</h3>
      <p class="text-sm text-surface-400 mb-4">Earned money with Hermes Agent? We want to feature you.</p>
      <a href="/connect/" class="inline-block proximity-btn relative px-5 py-2.5 rounded-xl bg-brand-600 dark:bg-brand-500 hover:bg-brand-700 dark:hover:bg-brand-400 text-white dark:text-black font-semibold text-sm transition-all duration-200">
        Share Your Story →
      </a>
    </div>

    <!-- Newsletter -->
    <div class="mt-12 pt-8 border-t border-surface-800">
      <div class="max-w-md mx-auto">
        <h3 class="font-bold text-xl mb-1 text-center">Get more stories like this</h3>
        <p class="text-surface-500 mb-4 text-center">New use cases delivered to your inbox.</p>
        <NewsletterForm client:load />
      </div>
    </div>
  </article>

  <Footer client:load />
  <ScrollProgress client:load />
</BaseLayout>
