---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navbar from '../components/Navbar.svelte'
import NewsletterForm from '../components/NewsletterForm.svelte'
import ScrollProgress from '../components/ScrollProgress.svelte'
import Footer from '../components/Footer.svelte'
---

<BaseLayout title="Connect" description="Get in touch with Earn With Hermes">
  <Navbar client:load />

  <section class="max-w-3xl mx-auto px-6 pt-16 pb-20">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-surface-600 mb-6">
      <a href="/" class="hover:text-surface-400 transition-colors">Home</a>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-surface-400">Connect</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-3">Connect</h1>
    <p class="text-surface-400 mb-10">Get in touch with us</p>

    <!-- Contact form -->
    <div class="rounded-2xl bg-white dark:bg-surface-900/50 border border-surface-200 dark:border-surface-800 p-8 mb-12">
      <h2 class="text-lg font-bold mb-2">Send a message</h2>
      <p class="text-sm text-surface-500 dark:text-surface-500 mb-6">Have a question, idea, or want to collaborate? Drop us a note.</p>

      <form id="contactForm" class="space-y-4">
        <div>
          <label for="name" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Name</label>
          <input type="text" id="name" name="name" required
            class="w-full px-4 py-2.5 rounded-lg bg-white dark:bg-surface-950 border border-surface-300 dark:border-surface-700 text-gray-900 dark:text-white text-sm placeholder:text-surface-400 dark:placeholder:text-surface-600 focus:outline-none focus:border-brand-500 transition-colors"
            placeholder="Your name" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Email</label>
          <input type="email" id="email" name="email" required
            class="w-full px-4 py-2.5 rounded-lg bg-white dark:bg-surface-950 border border-surface-300 dark:border-surface-700 text-gray-900 dark:text-white text-sm placeholder:text-surface-400 dark:placeholder:text-surface-600 focus:outline-none focus:border-brand-500 transition-colors"
            placeholder="your@email.com" />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Message</label>
          <textarea id="message" name="message" rows="5" required
            class="w-full px-4 py-2.5 rounded-lg bg-white dark:bg-surface-950 border border-surface-300 dark:border-surface-700 text-gray-900 dark:text-white text-sm placeholder:text-surface-400 dark:placeholder:text-surface-600 focus:outline-none focus:border-brand-500 transition-colors resize-vertical"
            placeholder="Your message..."></textarea>
        </div>
        <div class="flex justify-end">
          <button type="submit"
            class="px-6 py-2.5 rounded-xl bg-brand-600 dark:bg-brand-500 hover:bg-brand-700 dark:hover:bg-brand-400 text-white dark:text-black font-semibold text-sm transition-all duration-200">
            Send Message
          </button>
        </div>
        <p id="contactStatus" class="text-sm mt-2 hidden"></p>
      </form>
    </div>

    <!-- Share your story -->
    <div class="mb-12">
      <h2 class="text-lg font-bold mb-4">Share Your Story</h2>
      <p class="text-sm text-surface-400 mb-6">
        Have you earned money with Hermes Agent? We want to feature you.
      </p>
      <div class="space-y-3">
        <a href="#contactForm"
          class="flex items-center gap-3 text-sm text-surface-300 hover:text-brand-400 transition-colors cursor-pointer">
          <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-surface-800 flex items-center justify-center text-brand-400">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
            </svg>
          </span>
          <span>Use the <strong>contact form above</strong> to share your story</span>
        </a>
        <a href="https://x.com/autonomicshq" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-3 text-sm text-surface-300 hover:text-brand-400 transition-colors">
          <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-surface-800 flex items-center justify-center text-brand-400">X</span>
          <span>Tag <strong>@autonomicshq</strong> with your story on X/Twitter</span>
          <svg class="w-3 h-3 text-surface-600 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Newsletter -->
    <div class="pt-8 border-t border-surface-800">
      <div class="max-w-md mx-auto">
        <h3 class="font-bold text-xl mb-1 text-center">Stay Updated</h3>
        <p class="text-surface-500 mb-4 text-center">New use cases, tutorials, and money-making strategies.</p>
        <NewsletterForm client:load />
      </div>
    </div>
  </section>

  <Footer client:load />
  <ScrollProgress client:load />
</BaseLayout>

<script>
  const API = '/api'
  const form = document.getElementById('contactForm')
  const status = document.getElementById('contactStatus')

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const btn = form.querySelector('button[type="submit"]')
    if (!btn) return

    const nameInput = document.getElementById('name') as HTMLInputElement
    const emailInput = document.getElementById('email') as HTMLInputElement
    const msgInput = document.getElementById('message') as HTMLTextAreaElement

    // @ts-ignore
    btn.disabled = true
    btn.textContent = 'Sending…'

    try {
      const r = await fetch(API + '/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: nameInput?.value || '',
          email: emailInput?.value || '',
          message: msgInput?.value || '',
        }),
      })
      const d = await r.json()
      if (d.ok) {
        status!.textContent = "Thanks! We'll get back to you soon."
        status!.className = 'text-sm mt-2 text-brand-400'
        form!.reset()
      } else {
        status!.textContent = 'Error: ' + (d.error || 'unknown')
        status!.className = 'text-sm mt-2 text-red-400'
      }
    } catch {
      status!.textContent = 'Could not send. Try emailing connect@autonomics.build'
      status!.className = 'text-sm mt-2 text-red-400'
    }
    status!.classList.remove('hidden')
    // @ts-ignore
    btn.disabled = false
    btn.textContent = 'Send Message'
  })
</script>
