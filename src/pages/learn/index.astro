---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Navbar from '../../components/Navbar.svelte'
import NewsletterForm from '../../components/NewsletterForm.svelte'
import ScrollProgress from '../../components/ScrollProgress.svelte'
import Footer from '../../components/Footer.svelte'
import { getCollection } from 'astro:content'

const articles = await getCollection('articles', ({ data }) => !data.draft)
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<BaseLayout title="Learn" description="Tutorials, news, and opinions on making money with Hermes Agent.">
  <Navbar client:load />

  <section class="max-w-4xl mx-auto px-6 pt-16 pb-20">
    <div class="flex items-center gap-2 text-xs text-brand-400 font-medium mb-4">
      <span class="w-1.5 h-1.5 rounded-full bg-brand-400" />
      <span>{articles.length} {articles.length === 1 ? 'article' : 'articles'}</span>
    </div>
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-4">Learn</h1>
    <p class="text-surface-400 max-w-2xl leading-relaxed">
      Tutorials, news, and opinions on making money with Hermes Agent.
    </p>

    {articles.length === 0 && (
      <div class="mt-16 text-center">
        <p class="text-surface-500">No articles yet. Check back soon!</p>
      </div>
    )}

    <div class="mt-10 space-y-4">
      {articles.map(article => (
        <a href={`/learn/${article.id}/`}
          class="proximity-glow block rounded-2xl bg-surface-900/50 border border-surface-800 p-6 md:p-8 transition-all duration-200">
          <div class="flex items-center gap-3 text-xs text-surface-500 mb-3">
            <time>{new Date(article.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
            {article.data.categories?.[0] && (
              <>
                <span class="w-1 h-1 rounded-full bg-surface-700" />
                <span class="px-2 py-0.5 rounded bg-brand-500/10 text-brand-400 font-medium">{article.data.categories[0]}</span>
              </>
            )}
          </div>
          <h2 class="text-lg md:text-xl font-bold mb-2 hover:text-brand-400 transition-colors">
            {article.data.title}
          </h2>
          <p class="text-sm text-surface-400 leading-relaxed">{article.data.description}</p>
          <div class="flex gap-2 mt-4">
            {article.data.tags?.slice(0, 3).map(tag => (
              <span class="px-2.5 py-1 rounded-full bg-surface-800 text-surface-500 text-xs">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <Footer client:load />
  <ScrollProgress client:load />
</BaseLayout>
